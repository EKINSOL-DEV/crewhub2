        <mxCell id="a3" style="endArrow=block;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ipc" target="orch"><mxGeometry relative="1" as="geometry" /></mxCell>
