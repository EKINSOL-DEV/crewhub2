  <diagram id="m4-arch" name="M4 Orchestration Architecture">
    <mxGraphModel dx="1500" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="panels" value="src/panels — NEW M4 PANELS (+2 registry entries; tree UI mounts inside existing sessions/chat panels)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1420" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="meetings/ (Lane G, EKI-14/19/21): StartMeetingDialog (participants, rounds, topic, context docs, model-policy row haiku/sonnet) · RoundTable live view (active-speaker pulse, ✅/💤 chips) · MeetingOutput + history · ActionItemsList → one-click convert_action_item → board task → RunWithAgentDialog (M3 reuse) · StandupView (Coffee Standup sticky notes)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="60" y="75" width="560" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="automation/ (Lane H, EKI-30/35/39): runs table (cron-describe, Cron Critter ⏰, 🚀 Run now, honest &quot;runs only while CrewHub is open&quot; copy) · ScheduleEditor (preview_cron next-3) · SequenceEditor ({{previous_output}} chip, halt-on-failure timeline) · RunHistory → transcripts · TemplateLibrary + composer insert popover (templates + slash commands/skills)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="640" y="75" width="540" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="sessions/SessionTree.tsx (Lane H, EKI-54): expandable subagent tree (live status, humanized names) · team groups when SessionMeta.team present · chat header subagent strip · click → transcript" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1200" y="75" width="240" height="115" as="geometry" />
        </mxCell>

        <mxCell id="stores" value="src/stores — UI STORES (M3 discipline: event → single-entity refetch, never payload-stuffed events)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="1420" height="120" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="meetings.ts / standups.ts (G) — fold MeetingChanged/StandupChanged → get_meeting + list_meeting_turns refetch" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="275" width="380" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="automation.ts (H) — fold RunChanged → get_run/list_run_results; templates.ts — SettingChanged{prompt_templates} + renderTemplate ({{var}} contract shared with Rust)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="460" y="275" width="480" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="sessions.ts (H, additive only) — pure buildSessionForest(metas): parent links, orphan-as-root, team grouping" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="960" y="275" width="480" height="65" as="geometry" />
        </mxCell>

        <mxCell id="ipc" value="TYPED IPC (tauri-specta — Lane 0 owns, FROZEN after T8) · DomainEvent += MeetingChanged · RunChanged · StandupChanged (templates ride SettingChanged) · meetings/standups/runs/sequences/templates CRUD + start_meeting/cancel_meeting/convert_action_item/run_standup/run_now/preview_cron" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="1420" height="70" as="geometry" />
        </mxCell>

        <mxCell id="orch" value="src-tauri/src/orchestrator/ — NEW LAYER (provider-neutral; composes engine/, never extends it; naming firewall holds)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="1420" height="190" as="geometry" />
        </mxCell>
        <mxCell id="o1" value="meeting.rs (T3, EKI-10 L): pure state machine gathering → round(r) → synthesis → complete (+cancelled/error), effects-as-data · driver: PERSIST-THEN-ACT (v1 recovery lesson) · dedicated per-(meeting,participant) haiku sessions · serial turns · timeout 120s + 1 retry → skip · transcript-offset refs (NO copied text) · boot recovery scan resumes at persisted round/turn" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="525" width="480" height="135" as="geometry" />
        </mxCell>
        <mxCell id="o2" value="standup.rs (T4): digest (tasks + ≤50 transcript items via read path) → exec_headless haiku, concurrency ≤2, 60s timeout, &quot;(no response 🤷)&quot; honesty rows" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="560" y="525" width="280" height="135" as="geometry" />
        </mxCell>
        <mxCell id="o3" value="scheduler.rs (T5): croner next_fire/due_runs (pure, injected clock) + tokio loop (30s cap tick) · missed-once-on-wake, never burst · app-must-be-running honesty" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="860" y="525" width="280" height="135" as="geometry" />
        </mxCell>
        <mxCell id="o4" value="dispatch.rs + substitute.rs (T5/T6): spec_json union prompt | sequence | standup · one path for cron / run-now / steps · {{previous_output}} (16 KB cap) · halt-on-failure · action_items.rs: tolerant last-fenced-JSON parser (zero items never blocks completion)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1160" y="525" width="280" height="135" as="geometry" />
        </mxCell>

        <mxCell id="engine" value="engine/ (M1, mostly reused) + store/ (Lane 0 T2/T7)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="710" width="1420" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="ProcessManager + provider registry (spawn/send/interrupt, status fold, Signal{stop}) — meeting turns ride SpawnSpec.model = model_policy (haiku default)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="60" y="745" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="headless.rs SPLIT (T2, G5): exec_headless (pure, DEFAULT_HEADLESS_MODEL=haiku) + record_run_result(run_id, step_index) — synthesis/standups exec without a runs row" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="460" y="745" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="lineage.rs (T7, EKI-47): subagent dir-layout lineage EXISTS from M1 — M4 adds SessionMeta.team: Option&lt;TeamInfo&gt;, detection from T1 spike fixtures or parse-tolerant skeleton (never panics)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="860" y="745" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="store/{meetings,standups,runs,prompt_templates}.rs (T2, tables exist since M0) · migration 003: run_results.step_index (one ALTER)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="745" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="harness" value="fake-claude (src-tauri/src/bin): emit · expect_stdin · expect_arg · write_transcript · sleep_ms · mcp_call — M4 adds per-spawn scenario selection (G11) for 3-participant meeting tests; e2e/meeting.spec.ts + e2e/automation.spec.ts are the milestone flagships" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="1420" height="60" as="geometry" />
        </mxCell>

        <mxCell id="note" value="Standing principles: HAIKU-DEFAULT bites hardest in M4 — gathering rounds, standups, scheduled runs all default haiku with ONE explicit upgrade (synthesis, default sonnet); model_policy.* settings keys, never hardcoded, test-asserted. Playfulness inventory D-M4-10 (Round Table · Gavel Drop · Coffee Standup · Cron Critter · Quiet Orchestra), reduced-motion-aware. GATES: M3 dogfood week green-lit/waived before execution; T1 Q1 spike (½ day, CC teams vs round-robin) gates T3." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="960" width="1420" height="80" as="geometry" />
        </mxCell>

